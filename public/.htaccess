# Assets are referenced with ?v=<version> URLs, so they may be cached
# forever; everything dynamic sends Cache-Control: no-store itself.
<IfModule mod_headers.c>
    <FilesMatch "\.(css|js|svg)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# HSTS: once a browser has loaded this over HTTPS it upgrades any later
# http:// to https:// ITSELF, before sending - closing the one pre-redirect
# window the 301 leaves open. An old client (a TV browser, anything not
# HSTS-aware) just ignores an unknown header, so it never blocks anyone; the
# TLS 1.2 floor the host already enforces is the real gate. No
# includeSubDomains on purpose: this binds only this host, not the rest of
# poggensee.it. php -S ignores .htaccess, so this is verified on live, not
# in the smoke test.
<IfModule mod_headers.c>
    Header always set Strict-Transport-Security "max-age=31536000"
</IfModule>

# THE clock source clients sync against (docs/API.md, "Time
# synchronization and PTS"). Apache stamps the moment it RECEIVED the
# request into the header, in MICROseconds, and serves the file without
# PHP - so clock sync never queues for a PHP-FPM worker. That queue wait
# happens before PHP starts, so PHP can neither see nor subtract it, and
# it would land in the client's offset as if it were network delay.
#
# php -S ignores .htaccess entirely, so nothing here is covered by the
# smoke test: only real Apache can prove it works. Verified on live in
# 0.16.3, which is why this shipped alone first.
#
# no-store is not optional: a cached timestamp is a wrong clock. The
# immutable rule above matches on extension and never sees this file, but
# a proxy default might.
#
# Allow-Origin is * rather than the FOK_ALLOWED_ORIGINS allowlist the PHP
# endpoints use: this file bypasses PHP, so it cannot consult that list,
# and it discloses nothing the HTTP Date header does not already.
# Expose-Headers is what lets a browser read X-Fok-T cross-origin at all.
<IfModule mod_headers.c>
    <Files "t.txt">
        Header set X-Fok-T "%t"
        Header set Cache-Control "no-store"
        Header set Access-Control-Allow-Origin "*"
        Header set Access-Control-Expose-Headers "X-Fok-T"
    </Files>
</IfModule>
