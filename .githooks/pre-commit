#!/usr/bin/env bash
# Pre-commit gate: runs the same checks as CI (test/checks.sh).
# Enable once per clone:  git config core.hooksPath .githooks
# Skipped when PHP is not installed locally; CI still enforces everything.
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

if ! command -v php > /dev/null 2>&1; then
    echo "pre-commit: php not found, skipping checks (CI will run them)"
    exit 0
fi

bash test/checks.sh
